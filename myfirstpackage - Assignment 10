#' Say Hello
#'
#' This function generates a friendly greeting.
#'
#' @param name A character string representing a name.
#' @return A character string greeting the user.
#' @export
#'
#' @examples
#' say_hello("Raven")
say_hello <- function(name) {
  paste("Hello,", name, "!")
}

